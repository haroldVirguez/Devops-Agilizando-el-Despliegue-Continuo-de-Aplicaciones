# Copy to .env for local development (not committed).
FLASK_ENV=development
# PostgreSQL (RDS / local) via psycopg2-binary. For Elastic Beanstalk, set in environment properties.
# If the provider gives postgres://..., the app normalizes it to postgresql://...
DATABASE_URL=postgresql://user:password@localhost:5432/blacklist_db
# Same secret used to sign JWTs; use a long random string in production.
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
# Optional: skip automatic db.create_all() on startup (set to 1 to skip)
# SKIP_DB_CREATE_ALL=

# Postman: Authorization: Bearer <token>
# Create an HS256 JWT access token with exp in the far future using this secret (e.g. jwt.io).
